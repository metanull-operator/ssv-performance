# Ethereum network to use
# Possible values: mainnet, holesky, hoodi
#NETWORK=mainnet

# Number of days of zero performance after which an operator's validator count is reset to zero
#MISSING_PERFORMANCE_DAYS=7

# Number of API requests per minute to limit the bot's performance data collection
#REQUESTS_PER_MINUTE=20

# Log level for the collector script
# Possible values: DEBUG, INFO, WARNING, ERROR, CRITICAL
#ENV COLLECTOR_LOG_LEVEL=INFO

# Verified Operator Staleness Sweep
#
# At the end of each collector run, operators whose DB record has not been
# refreshed from the SSV API within VO_STALENESS_DAYS are demoted
# (is_vo set to 0 and vo_demoted_at stamped with the current date).
# The sweep is skipped if today's fetch looks unhealthy, so a degraded
# or partial API response cannot silently strip verified status from
# every operator.

# Demote is_vo=1 operators whose record has not been refreshed in this
# many days. Default 14.
#VO_STALENESS_DAYS=14

# Absolute sanity floor: skip the sweep if today's fetch returned fewer
# than this many operators. Default 100 (appropriate for mainnet; lower
# for testnets).
#VO_SWEEP_MIN_OPERATORS=100

# Coverage check: skip the sweep if today's fetch covers less than this
# fraction of operators seen in the DB within the last VO_STALENESS_DAYS
# days. Default 0.9.
#VO_SWEEP_MIN_COVERAGE=0.9